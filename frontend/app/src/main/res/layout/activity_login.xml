<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Login card, vertically centered via ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:minHeight="560dp"
            android:paddingVertical="32dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                app:cardBackgroundColor="@color/bg_login_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:gravity="center_horizontal">

                    <!-- Logo ring + image -->
                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_logo_ring"
                            android:padding="2dp"
                            android:contentDescription="@string/logo_desc"/>

                        <ImageView
                            android:id="@+id/imgLogo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@mipmap/ic_launcher"
                            android:padding="12dp"
                            android:contentDescription="@string/logo_desc"/>
                    </FrameLayout>

                    <!-- App name -->
                    <TextView
                        android:id="@+id/tvTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_title"
                        android:textColor="@color/accent_cyan"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp"/>

                    <!-- Subtitle -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONTROLE DE ESTUFAS AUTÔNOMAS"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.15"
                        android:textAllCaps="true"
                        android:layout_marginBottom="28dp"/>

                    <!-- Email field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="@string/login_email_hint"
                        style="@style/Widget.HabitatZero.TextInputLayout"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="@color/accent_cyan_dim">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:hint="@string/login_password_hint"
                        style="@style/Widget.HabitatZero.TextInputLayout"
                        app:passwordToggleEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_lock_lock"
                        app:startIconTint="@color/accent_cyan_dim">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSenha"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Login button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEntrar"
                        style="@style/Widget.HabitatZero.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/login_button_text"
                        android:textColor="@color/bg_primary"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        app:icon="@android:drawable/ic_menu_send"
                        app:iconGravity="end"
                        app:iconTint="@color/bg_primary"/>

                    <!-- Forgot password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Esqueci minha senha"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Footer: SYS.ONLINE (left) + version (right), anchored to bottom -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SYS.ONLINE"
        android:textColor="@color/accent_cyan"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v2.4.1"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"/>

</FrameLayout>
