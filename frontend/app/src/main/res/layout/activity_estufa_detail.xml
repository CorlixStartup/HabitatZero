<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationContentDescription="Voltar"
            app:titleTextColor="@color/text_primary"
            app:title="Estufa"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ─── CARD: INFORMAÇÕES ─── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/sensor_normal_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ Informações"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:id="@+id/tvInfoLocalizacao"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:text="📍 —"/>

                        <TextView
                            android:id="@+id/tvInfoCapacidade"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:text="— m²"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thresholds configurados"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2">

                        <TextView android:id="@+id/tvThreshO2"   android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:textColor="@color/sensor_oxigenio"   android:textSize="12sp" android:text="🫧 O₂ min: —"/>
                        <TextView android:id="@+id/tvThreshUmid" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:textColor="@color/sensor_umidade"     android:textSize="12sp" android:text="💧 Umid min: —"/>
                        <TextView android:id="@+id/tvThreshRad"  android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:textColor="@color/sensor_radiacao"    android:textSize="12sp" android:text="☢ Rad max: —"/>
                        <TextView android:id="@+id/tvThreshTemp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:textColor="@color/sensor_temperatura"  android:textSize="12sp" android:text="🌡 Temp max: —"/>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CARD: SISTEMAS DA COLÔNIA ─── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/azul_neon"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛸 Sistemas da Colônia"
                        android:textColor="@color/azul_neon"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginBottom="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔵 Pressurização" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvPressao" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="101.3 kPa" android:textColor="@color/sensor_umidade" android:textSize="18sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginBottom="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ Energia Solar" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvEnergia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="88%" android:textColor="@color/sensor_oxigenio" android:textSize="18sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📡 Link Orbital" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvLink" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="● ATIVO" android:textColor="@color/verde_normal" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌀 Filtro CO₂" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvFiltroCo2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="92%" android:textColor="@color/sensor_radiacao" android:textSize="18sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CARD: CONTROLE DE AMBIENTE ─── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/sensor_normal_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙ Controle de Ambiente"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Ventilação -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchVentilacao"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="💨 Ventilação forçada"
                            android:textColor="@color/text_primary"/>

                        <ProgressBar
                            android:id="@+id/pbVentilacao"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- Irrigação -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchIrrigacao"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🚿 Irrigação automática"
                            android:textColor="@color/text_primary"/>

                        <ProgressBar
                            android:id="@+id/pbIrrigacao"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAjustarThresholds"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🌡 Ajustar Thresholds de Alerta →"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CARD: PLANTAS ─── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/sensor_normal_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🌿 Plantas em Cultivo"
                            android:textColor="@color/sensor_oxigenio"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAdicionarPlanta"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+ Adicionar"
                            android:textColor="@color/sensor_oxigenio"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSemPlantas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nenhuma planta cadastrada."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:visibility="gone"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPlantas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CARD: ALERTAS ─── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/sensor_normal_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠ Alertas desta Estufa"
                        android:textColor="@color/amarelo_atencao"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvSemAlertas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓ Nenhum alerta ativo."
                        android:textColor="@color/verde_normal"
                        android:textSize="13sp"
                        android:visibility="gone"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerAlertasDetalhe"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
