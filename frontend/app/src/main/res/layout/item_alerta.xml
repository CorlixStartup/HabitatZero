<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:foreground="@drawable/ripple_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent">

    <!-- card content drawn over bg_card_critical drawable -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_critical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Top row: severity badge + timestamp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvSeveridade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ATENCAO"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_badge"
                android:textColor="@color/alert_critical"
                android:layout_marginEnd="8dp"/>

            <!-- Spacer -->
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvCriadoEm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Message -->
        <TextView
            android:id="@+id/tvMensagem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mensagem do alerta"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp"/>

        <!-- Resolve button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResolver"
            style="@style/Widget.HabitatZero.Button.OutlinedCyan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Resolver"
            android:textColor="@color/bg_primary"
            android:textSize="11sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            app:backgroundTint="@color/accent_cyan"
            app:strokeWidth="0dp"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
