<?xml version="1.0" encoding="utf-8"?>
<!-- Warning alert card: bg_surface fill + 4dp left border in alert_warning -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_surface"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <item android:right="0dp" android:top="0dp" android:bottom="0dp"
          android:width="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/alert_warning"/>
            <corners android:topLeftRadius="12dp" android:bottomLeftRadius="12dp"/>
        </shape>
    </item>
</layer-list>
