<?xml version="1.0" encoding="utf-8"?>
<!-- Critical alert card: dark red fill + 4dp left border in alert_critical -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Card background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A0808"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- Left accent border 4dp -->
    <item android:right="0dp" android:top="0dp" android:bottom="0dp"
          android:width="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/alert_critical"/>
            <corners android:topLeftRadius="12dp" android:bottomLeftRadius="12dp"/>
        </shape>
    </item>
</layer-list>
