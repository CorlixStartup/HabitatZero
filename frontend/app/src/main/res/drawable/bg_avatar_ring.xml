<?xml version="1.0" encoding="utf-8"?>
<!-- Avatar ring: outer glow layer (accent_cyan 30% alpha) + 3dp border layer -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item android:top="-4dp" android:bottom="-4dp"
          android:left="-4dp" android:right="-4dp">
        <shape android:shape="oval">
            <solid android:color="#4D00E5CC"/>
        </shape>
    </item>
    <!-- Accent border -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="3dp" android:color="@color/accent_cyan"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</layer-list>
