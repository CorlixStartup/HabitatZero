<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Button: Primary (cyan fill, dark text) ──────────────── -->
    <style name="Widget.HabitatZero.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/accent_cyan</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="rippleColor">@color/bg_primary</item>
    </style>

    <!-- ── Button: Destructive (transparent, red border) ───────── -->
    <style name="Widget.HabitatZero.Button.Destructive" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/alert_critical</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="strokeColor">@color/alert_critical</item>
        <item name="strokeWidth">@dimen/border_width</item>
        <item name="rippleColor">@color/alert_critical</item>
    </style>

    <!-- ── Button: Outlined Cyan ────────────────────────────────── -->
    <style name="Widget.HabitatZero.Button.OutlinedCyan" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="strokeColor">@color/accent_cyan</item>
        <item name="strokeWidth">@dimen/border_width</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="rippleColor">@color/accent_cyan</item>
    </style>

    <!-- ── Card: Standard ───────────────────────────────────────── -->
    <style name="Widget.HabitatZero.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">@dimen/border_width</item>
    </style>

    <!-- ── Card: Dark ────────────────────────────────────────────── -->
    <style name="Widget.HabitatZero.Card.Dark" parent="Widget.HabitatZero.Card">
        <item name="cardBackgroundColor">@color/bg_card_dark</item>
    </style>

    <!-- ── TextInput: Outlined Dark ─────────────────────────────── -->
    <style name="Widget.HabitatZero.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_primary</item>
        <item name="boxStrokeColor">@color/border_subtle</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_radius</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="startIconTint">@color/accent_cyan_dim</item>
    </style>

    <!-- ── Section Header: base ─────────────────────────────────── -->
    <style name="Widget.HabitatZero.SectionHeader" parent="">
        <item name="android:textSize">@dimen/text_xl</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ── Section Header: Critical ─────────────────────────────── -->
    <style name="Widget.HabitatZero.SectionHeader.Critical">
        <item name="android:textColor">@color/alert_critical</item>
    </style>

    <!-- ── Section Header: Warning ──────────────────────────────── -->
    <style name="Widget.HabitatZero.SectionHeader.Warning">
        <item name="android:textColor">@color/alert_warning</item>
    </style>

    <!-- ── Backward compat aliases kept to avoid regressions ────── -->
    <style name="Widget.MaterialComponents.Button.Filled" parent="Widget.HabitatZero.Button.Primary"/>
    <style name="Widget.MaterialComponents.Button.OutlinedButton" parent="Widget.HabitatZero.Button.OutlinedCyan"/>

</resources>
